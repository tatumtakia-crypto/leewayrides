    <main class="content-section">
        <h1>Schedule, Contact & Partnerships</h1>
        <p style="text-align: center; color: #ddd; margin-bottom: 40px;">Book your trip through our calendar, submit a partnership inquiry, or reach out to our team.</p>
        
        <!-- Cal.com Inline Booking Embed Integration -->
        <div class="booking-calendar-box" style="text-align: center;">
            <h3>Book Your Ride Online</h3>
            <p style="color: #ccc; font-size: 0.9rem; margin-bottom: 20px;">Select your preferred time slot below to secure your ride reservation.</p>
            
            <!-- Cal inline embed code begins -->
