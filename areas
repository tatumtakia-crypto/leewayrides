        .content-section { padding: 60px 5%; max-width: 900px; margin: auto; }
        .content-section h1 { font-size: 2.3rem; color: var(--accent-gold); margin-bottom: 20px; text-transform: uppercase; text-align: center; }
        .content-section p { margin-bottom: 20px; color: #ddd; text-align: center; }
        .areas-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(250px, 1fr)); gap: 20px; margin-top: 30px; margin-bottom: 40px; }
        .area-card { background: var(--secondary-purple); border: 1px solid rgba(243, 173, 33, 0.4); padding: 25px; border-radius: 12px; text-align: center; }
        .area-card h3 { color: var(--accent-gold); margin-bottom: 10px; font-size: 1.2rem; }
        .area-card p { color: #ccc; font-size: 0.9rem; margin-bottom: 0; }
        .map-container { background: var(--secondary-purple); border: 2px solid var(--accent-gold); padding: 30px; border-radius: 15px; text-align: center; margin-top: 40px; }
